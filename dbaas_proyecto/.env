# IPs de los microservicios (Cambia por las IPs reales de tus MVs)
AUTH_GRPC_HOST=IP_DE_MV3:50051
DB_GRPC_HOST=IP_DE_WINDOWS:50052
QUERY_GRPC_HOST=IP_DE_MV2:50053

# Configuración de RabbitMQ para el Gateway
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Configuración JWT (Debe ser igual en todos los servicios para validar tokens)
JWT_SECRET=super_secret_key
JWT_ALGORITHM=HS256